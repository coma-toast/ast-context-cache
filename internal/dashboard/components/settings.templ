package components

import "fmt"

type AgentInfo struct {
	Type            string
	Name            string
	GlobalPath      string
	ProjectPath     string
	Description     string
	GlobalInstalled bool
	ProjectInstalled bool
}

type DocSource struct {
	ID          int
	Name        string
	Type        string
	URL         string
	Version     string
	LastUpdated string
}

type SettingsData struct {
	IdleUnloadMinutes       int
	WatcherIgnoreGlobs      string
	IndexLogFiles           bool
	LogRetentionEnabled     bool
	LogRetentionRoots       string
	LogRetentionMaxAgeDays  int
	LogRetentionMaxTotalMB  int
	LogRetentionDryRun      bool
	LogRetentionLastRun     string
	EmbedBackend            string
	EmbedModelDir           string
	EmbedHTTPURL            string
	EmbedHTTPBearer         string
	EmbedOllamaHost         string
	EmbedOllamaModel        string
	EmbedOpenAIBaseURL      string
	EmbedOpenAIAPIKey       string
	EmbedOpenAIModel        string
	EmbedOpenAIDimensions   string
	EmbedDockerURL          string
	EmbedDockerModel        string
	EmbedDockerDimensions   string
	Projects                []Project
	Agents                  []AgentInfo
	DocSources              []DocSource
}

templ Settings(data SettingsData) {
	<div class="section">
		<div class="section-title">Performance</div>
		<div class="perf-setting">
			<label for="idleUnloadMinutes">Idle unload timeout (minutes)</label>
			<input type="number" id="idleUnloadMinutes" min="0" step="1" value={ fmt.Sprint(data.IdleUnloadMinutes) } class="perf-input"
				hx-post="/api/settings" hx-trigger="change" hx-swap="none"
				hx-vals='{"key":"idle_unload_minutes"}' hx-include="this"
				name="value"/>
			<span class="perf-hint">Embedder model, vector cache, and file watchers are unloaded after this many minutes of inactivity. Set to 0 to keep loaded.</span>
		</div>
	</div>

	<div class="section">
		<div class="section-title">Embedding backend</div>
		<p class="perf-hint" style="margin-bottom:12px">
			Values are stored in the local database under the <span class="mono">same names as environment variables</span>.
			If a process env var is <strong>set and non-empty</strong>, it overrides the dashboard for that key.
			<strong>Restart ast-mcp</strong> after changing anything here so the embedder reloads.
		</p>
		<form class="perf-setting" hx-post="/api/settings" hx-trigger="change from:select" hx-swap="none">
			<label for="embedBackend">EMBED_BACKEND</label>
			<input type="hidden" name="key" value="EMBED_BACKEND"/>
			<select id="embedBackend" class="perf-input" name="value">
				<option value="onnx" if data.EmbedBackend == "" || data.EmbedBackend == "onnx" { selected }>onnx (local default)</option>
				<option value="ollama" if data.EmbedBackend == "ollama" { selected }>ollama</option>
				<option value="http" if data.EmbedBackend == "http" { selected }>http (ast JSON /embed)</option>
				<option value="openai" if data.EmbedBackend == "openai" { selected }>openai (OpenAI / LiteLLM)</option>
				<option value="litellm" if data.EmbedBackend == "litellm" { selected }>litellm (same as openai)</option>
				<option value="docker" if data.EmbedBackend == "docker" { selected }>docker (Docker Model Runner)</option>
			</select>
		</form>
		<p class="perf-hint" style="margin-top:8px">
			<span class="mono">docker</span> backend: enable Docker Model Runner + TCP on port <span class="mono">12434</span>, then <span class="mono">docker model pull ai/qwen3-embedding</span>. See <span class="mono">docker/README.md</span>. Re-index after switching backends.
		</p>
		<div class="perf-setting">
			<label for="embedDockerURL">EMBED_DOCKER_URL</label>
			<input type="text" id="embedDockerURL" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" placeholder="http://127.0.0.1:12434" name="value" value={ data.EmbedDockerURL }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_DOCKER_URL"}' hx-include="this"/>
			<span class="perf-hint"><span class="mono">/engines/v1</span> is appended automatically when omitted.</span>
		</div>
		<div class="perf-setting">
			<label for="embedDockerModel">EMBED_DOCKER_MODEL</label>
			<input type="text" id="embedDockerModel" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" placeholder="ai/qwen3-embedding" name="value" value={ data.EmbedDockerModel }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_DOCKER_MODEL"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedDockerDimensions">EMBED_DOCKER_DIMENSIONS</label>
			<input type="text" id="embedDockerDimensions" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" placeholder="768" name="value" value={ data.EmbedDockerDimensions }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_DOCKER_DIMENSIONS"}' hx-include="this"/>
			<span class="perf-hint">Vector index requires 768 dimensions. Use <span class="mono">0</span> to omit the JSON field.</span>
		</div>
		<div class="perf-setting">
			<label for="embedModelDir">MODEL_DIR (optional)</label>
			<input type="text" id="embedModelDir" class="perf-input" style="width:100%" name="value" value={ data.EmbedModelDir }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"MODEL_DIR"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedHttpURL">EMBED_HTTP_URL</label>
			<input type="text" id="embedHttpURL" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedHTTPURL }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_HTTP_URL"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedHttpBearer">EMBED_HTTP_BEARER</label>
			<input type="text" id="embedHttpBearer" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedHTTPBearer }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_HTTP_BEARER"}' hx-include="this" autocomplete="off"/>
		</div>
		<div class="perf-setting">
			<label for="embedOllamaHost">OLLAMA_HOST</label>
			<input type="text" id="embedOllamaHost" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedOllamaHost }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"OLLAMA_HOST"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedOllamaModel">OLLAMA_EMBED_MODEL</label>
			<input type="text" id="embedOllamaModel" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedOllamaModel }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"OLLAMA_EMBED_MODEL"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedOpenAIBase">EMBED_OPENAI_BASE_URL</label>
			<input type="text" id="embedOpenAIBase" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedOpenAIBaseURL }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_OPENAI_BASE_URL"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedOpenAIKey">EMBED_OPENAI_API_KEY</label>
			<input type="text" id="embedOpenAIKey" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedOpenAIAPIKey }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_OPENAI_API_KEY"}' hx-include="this" autocomplete="off"/>
		</div>
		<div class="perf-setting">
			<label for="embedOpenAIModel">EMBED_OPENAI_MODEL</label>
			<input type="text" id="embedOpenAIModel" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedOpenAIModel }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_OPENAI_MODEL"}' hx-include="this"/>
		</div>
		<div class="perf-setting">
			<label for="embedOpenAIDim">EMBED_OPENAI_DIMENSIONS (empty DB = 768; 0 = omit field)</label>
			<input type="text" id="embedOpenAIDim" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px" name="value" value={ data.EmbedOpenAIDimensions }
				hx-post="/api/settings" hx-trigger="change delay:400ms" hx-swap="none"
				hx-vals='{"key":"EMBED_OPENAI_DIMENSIONS"}' hx-include="this"/>
		</div>
	</div>

	<div class="section">
		<div class="section-title">File watcher &amp; indexing</div>
		<p class="perf-hint" style="margin-bottom:12px">
			Plain <span class="mono">.log</span> files are not indexed unless you enable log search below.
			Ignore patterns apply to paths that would otherwise be indexed as code (or as logs when enabled)—for example generated sources under <span class="mono">dist/</span> or <span class="mono">*.pb.go</span>.
		</p>
		<form class="perf-setting" hx-post="/api/settings" hx-swap="none">
			<input type="hidden" name="key" value="watcher_ignore_globs"/>
			<label for="watcherIgnoreGlobs">Watcher ignore globs (JSON array)</label>
			<textarea id="watcherIgnoreGlobs" name="value" rows="5" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px">{ data.WatcherIgnoreGlobs }</textarea>
			<span class="perf-hint">Example: <span class="mono">["dist/**","**/*.pb.go","gen/*"]</span>. Applied after <span class="mono">IsCodeFile</span> (and log indexing when enabled).</span>
			<button type="submit" class="action-btn" style="margin-top:8px">Save ignore patterns</button>
		</form>
		<form class="perf-setting" style="margin-top:16px" hx-post="/api/settings" hx-trigger="change from:select" hx-swap="none">
			<label for="indexLogFiles">Index <span class="mono">.log</span> / <span class="mono">.txt</span> (BM25/FTS search only, no embeddings)</label>
			<input type="hidden" name="key" value="index_log_files"/>
			<select id="indexLogFiles" class="perf-input" name="value">
				if data.IndexLogFiles {
					<option value="false">Off</option>
					<option value="true" selected>On</option>
				} else {
					<option value="false" selected>Off</option>
					<option value="true">On</option>
				}
			</select>
		</form>
	</div>

	<div class="section">
		<div class="section-title">Log retention (optional)</div>
		<p class="perf-hint" style="margin-bottom:12px">
			Deletes only <span class="mono">.log</span> files under absolute directory roots you list. Disabled by default; use dry-run first.
		</p>
		<form class="perf-setting" hx-post="/api/settings" hx-trigger="change from:select" hx-swap="none">
			<label for="logRetentionEnabled">Enable log retention job</label>
			<input type="hidden" name="key" value="log_retention_enabled"/>
			<select id="logRetentionEnabled" class="perf-input" name="value">
				if data.LogRetentionEnabled {
					<option value="false">Off</option>
					<option value="true" selected>On</option>
				} else {
					<option value="false" selected>Off</option>
					<option value="true">On</option>
				}
			</select>
		</form>
		<form class="perf-setting" hx-post="/api/settings" hx-swap="none">
			<input type="hidden" name="key" value="log_retention_roots"/>
			<label for="logRetentionRoots">Absolute roots (JSON array of strings)</label>
			<textarea id="logRetentionRoots" name="value" rows="3" class="perf-input" style="width:100%;font-family:ui-monospace,monospace;font-size:12px">{ data.LogRetentionRoots }</textarea>
			<span class="perf-hint">Example: <span class="mono">["/var/log/myapp","/Users/me/proj/logs"]</span></span>
			<button type="submit" class="action-btn" style="margin-top:8px">Save roots</button>
		</form>
		<form class="perf-setting" hx-post="/api/settings" hx-trigger="change" hx-swap="none">
			<label for="logRetentionMaxAge">Max age (days, 0 = unused)</label>
			<input type="hidden" name="key" value="log_retention_max_age_days"/>
			<input type="number" id="logRetentionMaxAge" min="0" step="1" class="perf-input" name="value" value={ fmt.Sprint(data.LogRetentionMaxAgeDays) }/>
		</form>
		<form class="perf-setting" hx-post="/api/settings" hx-trigger="change" hx-swap="none">
			<label for="logRetentionMaxMB">Max total size across roots (MiB, 0 = unused)</label>
			<input type="hidden" name="key" value="log_retention_max_total_mib"/>
			<input type="number" id="logRetentionMaxMB" min="0" step="1" class="perf-input" name="value" value={ fmt.Sprint(data.LogRetentionMaxTotalMB) }/>
		</form>
		<form class="perf-setting" hx-post="/api/settings" hx-trigger="change from:select" hx-swap="none">
			<label for="logRetentionDryRun">Dry run (log only, no deletes)</label>
			<input type="hidden" name="key" value="log_retention_dry_run"/>
			<select id="logRetentionDryRun" class="perf-input" name="value">
				if data.LogRetentionDryRun {
					<option value="false">Off</option>
					<option value="true" selected>On</option>
				} else {
					<option value="false" selected>Off</option>
					<option value="true">On</option>
				}
			</select>
		</form>
		if data.LogRetentionLastRun != "" {
			<div class="perf-hint mono" style="margin-top:8px">Last run: { data.LogRetentionLastRun }</div>
		}
	</div>

	<div class="section">
		<div class="section-title">Projects</div>
		<div class="project-list">
			if len(data.Projects) == 0 {
				<div class="empty-state">No indexed projects</div>
			} else {
				for _, p := range data.Projects {
					<div class="project-item">
						<div class="info">
							<div class="name">{ p.Name }</div>
							<div class="path" title={ p.Path }>{ p.Path }</div>
						</div>
						<div class="actions">
							if p.Pinned {
								<button class="action-btn" title="Pinned: priority embedding and longer vector warm" hx-post="/api/pin-project" hx-vals={ fmt.Sprintf(`{"project_path":"%s","pinned":false}`, p.Path) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-headers='{"Content-Type":"application/json"}'>Unpin</button>
							} else {
								<button class="action-btn" title="Pin for priority embedding and warmer vectors" hx-post="/api/pin-project" hx-vals={ fmt.Sprintf(`{"project_path":"%s","pinned":true}`, p.Path) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-headers='{"Content-Type":"application/json"}'>Pin</button>
							}
							<button class="action-btn" hx-post="/api/reset-project" hx-vals={ fmt.Sprintf(`{"project_path":"%s"}`, p.Path) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-headers='{"Content-Type":"application/json"}'>Reset</button>
							<button class="action-btn danger" hx-post="/api/delete-watcher" hx-vals={ fmt.Sprintf(`{"project_path":"%s"}`, p.Path) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-confirm={ fmt.Sprintf("Delete %s? This removes all indexed data.", p.Name) } hx-headers='{"Content-Type":"application/json"}'>Delete</button>
						</div>
					</div>
				}
			}
		</div>
	</div>

	<div class="section">
		<div class="section-title">Agent Integration</div>
		<p style="color: var(--text-dim); margin-bottom: 16px; font-size: 13px;">
			Install context instructions for your AI coding agents.
		</p>
		<div class="agent-list">
			if len(data.Agents) == 0 {
				<div class="empty-state">No agents available</div>
			} else {
				for _, a := range data.Agents {
					<div class="agent-item">
						<div class="info">
							<div class="name">{ a.Name }</div>
							<div class="desc">{ a.Description }</div>
							<div class="paths">
								<span class="global">Global: { a.GlobalPath }</span>
								<span class="project">Project: { a.ProjectPath }</span>
							</div>
						</div>
						<div class="install-btns">
							if a.GlobalInstalled {
								<span class="installed-badge">Global</span>
							} else {
								<button class="action-btn" hx-post="/api/agent-install" hx-vals={ fmt.Sprintf(`{"agent_type":"%s","is_global":true}`, a.Type) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-headers='{"Content-Type":"application/json"}'>Global</button>
							}
							if a.ProjectInstalled {
								<span class="installed-badge">Project</span>
							} else {
								<button class="action-btn" hx-post="/api/agent-install" hx-vals={ fmt.Sprintf(`{"agent_type":"%s","is_global":false}`, a.Type) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-headers='{"Content-Type":"application/json"}'>Project</button>
							}
							if a.GlobalInstalled || a.ProjectInstalled {
								<button class="action-btn danger" hx-post="/api/agent-uninstall" hx-vals={ fmt.Sprintf(`{"agent_type":"%s","is_global":%t}`, a.Type, a.GlobalInstalled) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-confirm={ fmt.Sprintf("Remove %s configuration?", a.Name) } hx-headers='{"Content-Type":"application/json"}'>Remove</button>
							}
						</div>
					</div>
				}
			}
		</div>
	</div>

	<div class="section">
		<div class="section-title">Documentation Sources</div>
		<div class="card" style="padding:0;overflow-x:auto">
			<table>
				<thead>
					<tr>
						<th>Name</th>
						<th>Type</th>
						<th>URL</th>
						<th>Version</th>
						<th>Last Updated</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody>
					if len(data.DocSources) == 0 {
						<tr><td colspan="6" class="empty-state">No doc sources configured</td></tr>
					} else {
						for _, s := range data.DocSources {
							<tr>
								<td><strong>{ s.Name }</strong></td>
								<td><span class="badge badge-blue">{ s.Type }</span></td>
								<td class="mono" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title={ s.URL }>{ s.URL }</td>
								<td>
									if s.Version != "" {
										{ s.Version }
									} else {
										-
									}
								</td>
								<td class="mono dim">{ s.LastUpdated }</td>
								<td>
									<button class="badge badge-green" style="cursor:pointer;border:none" hx-post="/api/doc-sources" hx-vals={ fmt.Sprintf(`{"action":"update","id":%d}`, s.ID) } hx-target="#settings-content" hx-get="/partials/settings" hx-swap="innerHTML" hx-headers='{"Content-Type":"application/json"}'>Update</button>
								</td>
							</tr>
						}
					}
				</tbody>
			</table>
		</div>
	</div>
}
